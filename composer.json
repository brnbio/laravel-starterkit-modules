{
    "name": "brnbio/laravel-starterkit-modules",
    "description": "A modern Laravel starter kit with InertiaJS, Vue 3, Tailwind CSS, and Laravel Sail pre-configured for rapid application development",
    "type": "project",
    "license": "MIT",
    "homepage": "https://github.com/brnbio/laravel-starterkit-modules",
    "support": {
        "issues": "https://github.com/brnbio/laravel-starterkit-modules/issues",
        "source": "https://github.com/brnbio/laravel-starterkit-modules"
    },
    "authors": [
        {
            "name": "brainbo",
            "homepage": "https://github.com/brnbio"
        }
    ],
    "require": {
        "php": "^8.5",
        "laravel/sail": "^v1.46.0"
    },
    "scripts": {
        "post-root-package-install": [
            "@php -r \"file_exists('.env') || copy('.env.example', '.env');\""
        ]
    },
    "extra": {
        "laravel": {
            "dont-discover": []
        }
    },
    "config": {
        "optimize-autoloader": true,
        "preferred-install": "dist",
        "sort-packages": true
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}
